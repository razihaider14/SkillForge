APP_NAME = Portlio
ENV = development
HOST = 0.0.0.0
PORT = 8000

# optional GitHub Personal Access Token
# increases rate limit from 60/hour to 5000/hour
GITHUB_TOKEN =

# Comma-separated list of origins allowed to call this API from a browser
# (CORS). Defaults to the local Next.js dev server if unset. Add the
# production frontend URL here when deploying, e.g.:
# FRONTEND_ORIGINS = http://localhost:3000,https://portlio.example.com
FRONTEND_ORIGINS = 