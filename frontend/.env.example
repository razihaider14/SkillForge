# Base URL of the Portlio FastAPI backend (no trailing slash).
# Used by src/lib/api/client.ts (added in Phase 1).
#
# Local dev, running the backend from ../backend with `uvicorn app.main:app --reload`:
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Production example:
# NEXT_PUBLIC_API_BASE_URL=https://api.portlio.example.com
